<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>staybnb</title>
    <style>
        img{
            height: 200px;
            width: 200px;
            border-radius: 20px;
        }
    </style>
</head>
<body>
    <main>
        <h1>Edit Your Listing</h1>

        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
            <input type="text" value="<%= listing.title %>" name="listing[title]" placeholder="Enter Title"> <br> <br>
            <textarea name="listing[description]" placeholder="Enter Description"><%= listing.description %></textarea> <br> <br>
            <input type="text" value="<%= listing.image %>" name="listing[image]" placeholder="Enter Image URL"> <br> <br>
            <input type="number" value="<%= listing.price %>" name="listing[price]" placeholder="Enter Price"> <br> <br>
            <input type="text" value="<%= listing.location %>" name="listing[location]" placeholder="Enter Location"> <br> <br>
            <input type="text" value="<%= listing.country %>" name="listing[country]" placeholder="Enter Country"> <br> <br>
            <button>Edit</button>
        </form>

    </main>
</body>
</html>